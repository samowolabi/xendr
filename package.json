{
  "name": "xendr",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/www",
    "build": "npm run build -w packages/react",
    "build:site": "npm run build -w apps/www",
    "build:app": "npm run build -w apps/www",
    "check": "npm run lint && npm run build -w packages/react && npm run build -w apps/www",
    "lint": "oxlint",
    "pack:dry": "npm run build -w packages/react && npm pack -w packages/react --dry-run",
    "preview": "npm run preview -w apps/www"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/edge": "^1.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
